# AutoLotto — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit your actual .env file to GitHub

# ── Ethereum Network ──────────────────────────────────────
# Sepolia Testnet RPC URL
# Get a free key from: https://www.infura.io or https://www.alchemy.com
RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_ID

# ── Wallet ────────────────────────────────────────────────
# Your MetaMask wallet private key (owner wallet that deployed the contract)
# WARNING: Never share your private key or commit it to version control
PRIVATE_KEY=your_private_key_here

# ── Contract ──────────────────────────────────────────────
# Deployed AutoLotto contract address on Sepolia
CONTRACT_ADDRESS=0x7Cf12187dE99aBa948Dcb9260Dc9D817925ba16E

# ── Etherscan API (optional, for verification) ────────────
# Get free API key from: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ── Entry Fee ─────────────────────────────────────────────
# Minimum entry fee in Wei (0.01 ETH = 10000000000000000 Wei)
ENTRY_FEE_WEI=10000000000000000
